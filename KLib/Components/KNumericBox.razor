@using System.Globalization
@using System.Linq
@typeparam TValue

<KTextBox InputAttributes="_mergedAttributes" CssClass="@CssClass" InputType="@InputType" TextChangingMode="KTextBox.TextChangedMode.LostFocus"
          @ref="_textBoxObject" Placeholder="@Placeholder"
          Readonly="@Readonly" Text="@_text" TextChanged="OnTextChanged" TextExpression="()=>_text"/>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object> InputAttributes { get; set; } = new();
    private KTextBox? _textBoxObject;
    private string? _text { get; set; }
    private TValue? _oldValue { get; set; }
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public int? Decimals { get; set; }
    [Parameter] public string? Format { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Currency { get; set; }
    [Parameter] public bool Readonly { get; set; }
    [Parameter] public TValue? Min { get; set; }
    [Parameter] public TValue? Max { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string InputType { get; set; } = "text";

    // Aggiunge inputmode="decimal" automaticamente per tastiera numerica su mobile,
    // a meno che l'utente non l'abbia già specificato
    private Dictionary<string, object> _mergedAttributes =>
        InputAttributes.ContainsKey("inputmode")
            ? InputAttributes
            : new Dictionary<string, object>(InputAttributes) { ["inputmode"] = "decimal" };

    protected override void OnParametersSet()
    {
        //Se il valore cambia, lo valido
        if (!EqualityComparer<TValue>.Default.Equals(Value, _oldValue))
        {
            _oldValue = Value;
            ValidateValue();
        }

        base.OnParametersSet();
    }

    private void OnTextChanged(string? newText)
    {
        var oldText = _text;
        if (!string.IsNullOrEmpty(Currency) && newText?.Contains(Currency) == true)
            newText = newText.Replace(Currency, string.Empty);

        newText = newText?.Trim();
        _text = newText;

        if(string.IsNullOrEmpty(newText))
        {
            //Gestisco il caso di valore nullo
            Value = default;
            ValueChanged.InvokeAsync(Value);
            return;
        }

        // Normalizza in una stringa "invariant" (separatore decimale ".") gestendo in
        // modo robusto separatori multipli, di migliaia e input "sporco" (es. il valore
        // formattato con la valuta già presente nel campo, tipico su tastiere touch).
        var type = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);
        var allowsDecimals = type == typeof(decimal) || type == typeof(double) || type == typeof(float);
        var normalized = NormalizeNumericInput(newText, allowsDecimals);

        try
        {
            var method = type.GetMethod("Parse", new[] { typeof(string), typeof(IFormatProvider) });
            var parameters = new List<object> { normalized };
            if (method == null)
            {
                method = type.GetMethod("Parse", new[] { typeof(string) });
            }
            else
            {
                parameters.Add(CultureInfo.InvariantCulture);
            }

            if (method != null)
            {
                Value = (TValue)method.Invoke(null, parameters.ToArray())!;
                Value = ApplyDecimals(Value);
                ValueChanged.InvokeAsync(Value);
                ValidateValue();
                return;
            }
        }
        catch
        {
            _text = oldText;
            _textBoxObject?.Refresh();
        }

        _text = oldText;
        _textBoxObject?.Refresh();
    }

    /// <summary>
    /// Converte un input numerico potenzialmente "sporco" in una stringa canonica con "."
    /// come separatore decimale. Considera l'ultimo separatore (virgola o punto) come decimale
    /// e rimuove gli altri (separatori di migliaia/duplicati). Per i tipi interi rimuove ogni
    /// separatore. Tiene solo cifre, separatori e l'eventuale segno iniziale.
    /// </summary>
    private static string NormalizeNumericInput(string input, bool allowsDecimals)
    {
        var negative = input.TrimStart().StartsWith("-");
        var cleaned = new string(input.Where(char.IsDigit).ToArray());

        if (allowsDecimals)
        {
            var lastSep = Math.Max(input.LastIndexOf(','), input.LastIndexOf('.'));
            if (lastSep >= 0)
            {
                var intDigits = new string(input.Substring(0, lastSep).Where(char.IsDigit).ToArray());
                var fracDigits = new string(input.Substring(lastSep + 1).Where(char.IsDigit).ToArray());
                cleaned = fracDigits.Length > 0 ? $"{intDigits}.{fracDigits}" : intDigits;
            }
        }

        if (string.IsNullOrEmpty(cleaned))
            return negative ? "-0" : "0";

        return negative ? $"-{cleaned}" : cleaned;
    }

    private void ValidateValue()
    {
        Value = ApplyDecimals(Value);

        if (Min is IEquatable<TValue> iemin && Max is IEquatable<TValue> iemax)
        {
            if (Min != null && !iemin.Equals(iemax))
            {
                if (Comparer<TValue>.Default.Compare(Value, Min) < 0)
                {
                    Value = Min;
                    ValueChanged.InvokeAsync(Value);
                }
            }

            if (Max != null && !iemax.Equals(iemin) && Comparer<TValue>.Default.Compare(Max, Min) > 0)
            {
                if (Comparer<TValue>.Default.Compare(Value, Max) > 0)
                {
                    Value = Max;
                    ValueChanged.InvokeAsync(Value);
                }
            }
        }
        else if (Min != null || Max != null)
        {
            throw new NotSupportedException($"Type {typeof(TValue)} is not supported");
        }

        ConvertValueToText();
    }

    private TValue ApplyDecimals(TValue value)
    {
        if (!Decimals.HasValue)
            return value;

        var boxed = (object?)value;
        if (boxed == null)
            return value;

        var decimals = Decimals.Value;

        if (boxed is decimal dec)
            return (TValue)(object)Math.Round(dec, decimals, MidpointRounding.AwayFromZero);
        if (boxed is double dbl)
            return (TValue)(object)Math.Round(dbl, decimals, MidpointRounding.AwayFromZero);
        if (boxed is float fl)
            return (TValue)(object)MathF.Round(fl, decimals, MidpointRounding.AwayFromZero);

        return value;
    }

    private void ConvertValueToText()
    {
        // Usa sempre la cultura corrente: il campo è "text", accetta virgola/punto come da locale
        _text = Format != null && Value is IFormattable formattableValue
            ? formattableValue.ToString(Format, CultureInfo.CurrentCulture)
            : Value?.ToString() ?? string.Empty;

        if (!string.IsNullOrEmpty(Currency))
        {
            _text = $"{_text} {Currency}";
        }
    }

}

